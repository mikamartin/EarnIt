# Copy this file to keystore.properties (gitignored) and fill in the real values.
# keystore.properties must never be committed to git.
#
# storeFile    — absolute path to your .jks file, e.g. /Users/you/keys/earnit-upload.jks
# storePassword — password set when the keystore was created
# keyAlias      — alias chosen when the key was generated (e.g. earnit-key)
# keyPassword   — password for the key entry (may be the same as storePassword)

storeFile=
storePassword=
keyAlias=
keyPassword=
